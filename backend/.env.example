# =============================================
# Sky Camp Backend — Environment Variables
# Скопіюйте у .env і заповніть значення
# =============================================

# Server
PORT=3000
NODE_ENV=development

# Telegram Bot (отримайте в @BotFather)
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_GROUP_CHAT_ID_HERE

# Admin Panel
ADMIN_USER=admin
ADMIN_PASS=змініть_на_безпечний_пароль_мінімум_16_символів

# Sessions — згенеруйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# SMTP Email (необов'язково — без нього email не надсилається)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Sky Camp <noreply@sky-camp.pp.ua>

# CORS — URL вашого фронтенду (для продакшна)
FRONTEND_URL=https://sky-camp.pp.ua

# Database path (відносно папки backend/)
DB_PATH=./data/skycamp.db

# Логи у файл (1=так, 0=ні, в dev mode)
LOG_TO_FILE=0
